---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedEntries from '../components/RelatedEntries.astro';
import ReadingTime from '../components/ReadingTime.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Comments from '../components/Comments.astro';
import { getCollection } from 'astro:content';
import { categories, siteConfig } from '../config';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: CollectionEntry<'entries'>;
  headings?: Heading[];
}

const { entry, headings = [] } = Astro.props;
const user = Astro.locals.currentUser;
const { title, category, tags, date_created, date_updated, maturity, related, people_mentioned, life_stage, priority } = entry.data;

const categoryInfo = categories.find(c => c.id === category);
const allEntries = await getCollection('entries');

const relatedEntries = related
  .map(relatedSlug => allEntries.find(e => e.slug === relatedSlug))
  .filter(Boolean) as CollectionEntry<'entries'>[];

const backlinks = allEntries
  .filter(e => e.slug !== entry.slug && e.data.related.includes(entry.slug))
  .sort((a, b) => new Date(b.data.date_created).getTime() - new Date(a.data.date_created).getTime());

const tagRelated = tags.length > 0
  ? allEntries
      .filter(e => e.slug !== entry.slug && !related.includes(e.slug) && !backlinks.find(bl => bl.slug === e.slug))
      .map(e => ({
        entry: e,
        sharedTags: e.data.tags.filter(t => tags.includes(t)).length,
      }))
      .filter(x => x.sharedTags > 0)
      .sort((a, b) => b.sharedTags - a.sharedTags)
      .slice(0, 4)
      .map(x => x.entry)
  : [];

const siteIndexData = allEntries.map(entry => ({
  id: entry.id,
  title: entry.data.title,
  category: entry.data.category,
  tags: entry.data.tags,
  excerpt: entry.data.excerpt || '',
  maturity: entry.data.maturity || 'draft',
  date: entry.data.date_created.toISOString(),
}));

const categoryEntries = allEntries
  .filter(e => e.data.category === category)
  .sort((a, b) => new Date(b.data.date_created).getTime() - new Date(a.data.date_created).getTime());

const currentIdx = categoryEntries.findIndex(e => e.slug === entry.slug);
const prevEntry = currentIdx > 0 ? categoryEntries[currentIdx - 1] : null;
const nextEntry = currentIdx < categoryEntries.length - 1 ? categoryEntries[currentIdx + 1] : null;

const priorityColors: Record<string, string> = {
  critical: 'var(--color-error)',
  high: 'var(--color-warning)',
  medium: 'var(--color-text-muted)',
  low: 'var(--color-text-light)',
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: categoryInfo?.name || category, href: `/entries/${category}` },
  { label: title, href: Astro.url.pathname },
];
---

<BaseLayout title={title} description={entry.data.excerpt || siteConfig.description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: entry.data.excerpt || siteConfig.description,
    datePublished: date_created,
    dateModified: date_updated || date_created,
    author: { '@type': 'Person', name: siteConfig.author },
    publisher: { '@type': 'Person', name: siteConfig.author },
    mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(Astro.url.pathname, siteConfig.url).href },
    keywords: tags.join(', '),
    articleSection: category,
  })} />
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    <div
      id="site-index"
      data-value={encodeURIComponent(JSON.stringify(siteIndexData))}
      style="display:none"
    ></div>
    <div
      id="entry-id"
      data-value={entry.id}
      data-title={title}
      style="display:none"
    ></div>

    <article>
      <header class="entry-header">
        <div class="entry-header-top">
          <span class="entry-category-badge">
            {categoryInfo?.icon} {categoryInfo?.name}
          </span>
          {priority && priority !== 'medium' && (
            <span
              class="entry-priority-badge"
              style={`background: ${priorityColors[priority] || priorityColors.medium}; color: white;`}
            >
              {priority}
            </span>
          )}
          <div class="entry-header-actions">
            <button id="bookmark-btn" class="entry-action-btn" title="Bookmark (B)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
            </button>
            <button id="random-btn" class="entry-action-btn" title="Random entry (R)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
            </button>
            {user ? (
              <a href={`/admin/entries/edit/${entry.id}`} class="entry-action-btn" title="Edit this entry">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              </a>
            ) : null}
          </div>
        </div>

        <h1 class="entry-title">{title}</h1>

        <div class="entry-meta">
          <span class="entry-meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {new Date(date_created).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          {date_updated && (
            <span class="entry-meta-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              Updated: {new Date(date_updated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          )}
          <span class={`maturity-badge ${maturity}`}>{maturity}</span>
          <ReadingTime body={entry.body || ''} />
        </div>

        {life_stage && life_stage.length > 0 && (
          <div class="entry-extra-tags">
            {life_stage.map(stage => (
              <span class="entry-life-stage">🌱 {stage.replace(/-/g, ' ')}</span>
            ))}
          </div>
        )}

        {tags.length > 0 && (
          <div class="entry-card-tags" style="margin-top: var(--space-4);">
            {tags.map(tag => (
              <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">#{tag}</a>
            ))}
          </div>
        )}

        {people_mentioned && people_mentioned.length > 0 && (
          <div class="entry-people">
            <h4 class="entry-section-label">People mentioned</h4>
            <div class="entry-people-list">
              {people_mentioned.map(person => (
                <span class="entry-person-tag">{person}</span>
              ))}
            </div>
          </div>
        )}
      </header>

      <div class="entry-layout">
        <div class="entry-content">
          <slot />
        </div>
        <TableOfContents headings={headings} />
      </div>

      {backlinks.length > 0 && (
        <section class="entry-backlinks">
          <h3 class="entry-section-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
            Backlinks ({backlinks.length})
          </h3>
          <div class="entry-list">
            {backlinks.map(bl => (
              <a href={`/entries/${bl.slug}`} class="entry-card">
                <div class="entry-card-header">
                  <h3 class="entry-card-title" style="font-size: var(--text-base);">{bl.data.title}</h3>
                  <span class="entry-card-date">
                    {new Date(bl.data.date_created).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
                {bl.data.excerpt && <p class="entry-card-excerpt">{bl.data.excerpt}</p>}
              </a>
            ))}
          </div>
        </section>
      )}

      {tagRelated.length > 0 && (
        <RelatedEntries entries={tagRelated} title="Related by Tags" />
      )}

      {relatedEntries.length > 0 && (
        <RelatedEntries entries={relatedEntries} title="Directly Related" />
      )}

      {(prevEntry || nextEntry) && (
        <nav class="entry-prev-next">
          {prevEntry ? (
            <a href={`/entries/${prevEntry.slug}`} class="entry-prev-next-link entry-prev-next-prev">
              <span class="entry-prev-next-direction">← Previous</span>
              <span class="entry-prev-next-title">{prevEntry.data.title}</span>
            </a>
          ) : <div></div>}
          {nextEntry ? (
            <a href={`/entries/${nextEntry.slug}`} class="entry-prev-next-link entry-prev-next-next">
              <span class="entry-prev-next-direction">Next →</span>
              <span class="entry-prev-next-title">{nextEntry.data.title}</span>
            </a>
          ) : <div></div>}
        </nav>
      )}
      <Comments entryId={entry.id} user={user} />
    </article>
  </div>
</BaseLayout>

<script>
  import '../scripts/content-mgmt.ts';
</script>

<style>
  .entry-header-top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .entry-header-actions {
    margin-left: auto;
    display: flex;
    gap: var(--space-1);
  }

  .entry-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .entry-action-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .entry-priority-badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 10px;
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .entry-extra-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .entry-life-stage {
    display: inline-block;
    padding: 2px 8px;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-full);
  }

  .entry-people {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-light);
  }

  .entry-section-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .entry-people-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .entry-person-tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 3px 10px;
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
  }

  .entry-backlinks {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .entry-section-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .entry-prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .entry-prev-next-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .entry-prev-next-link:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
  }

  .entry-prev-next-prev {
    align-items: flex-start;
  }

  .entry-prev-next-next {
    align-items: flex-end;
    text-align: right;
  }

  .entry-prev-next-direction {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .entry-prev-next-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .entry-prev-next-link:hover .entry-prev-next-title {
    color: var(--color-accent);
  }

  .entry-layout {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: var(--space-8);
    align-items: start;
  }

  @media (max-width: 900px) {
    .entry-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .entry-prev-next {
      grid-template-columns: 1fr;
    }
    .entry-prev-next-next {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
