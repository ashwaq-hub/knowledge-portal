---
import { getDb, schema } from '../lib/db/index';
import { eq, asc } from 'drizzle-orm';

interface Comment {
  id: number;
  userId: number;
  parentId: number | null;
  body: string;
  createdAt: Date;
  username: string | null;
}

interface Props {
  entryId: string;
  user?: { id: number; email: string; username: string } | null;
}

const { entryId, user } = Astro.props;

let comments: Comment[] = [];
try {
  const db = getDb();
  comments = db
    .select({
      id: schema.comments.id,
      userId: schema.comments.userId,
      parentId: schema.comments.parentId,
      body: schema.comments.body,
      createdAt: schema.comments.createdAt,
      username: schema.users.username,
    })
    .from(schema.comments)
    .leftJoin(schema.users, eq(schema.comments.userId, schema.users.id))
    .where(eq(schema.comments.entryId, entryId))
    .orderBy(asc(schema.comments.createdAt))
    .all() as Comment[];
} catch {
  // DB not available
}

const roots = comments.filter(c => !c.parentId);
const replies = (parentId: number) => comments.filter(c => c.parentId === parentId);

function formatDate(d: Date): string {
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<section class="comments-section" id="comments">
  <h3 class="comments-title">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
    </svg>
    Comments ({comments.length})
  </h3>

  <div id="comments-list">
    {roots.length === 0 ? (
      <p class="comments-empty">No comments yet. {user ? 'Be the first!' : ''}</p>
    ) : (
      roots.map(comment => (
        <div class="comment" id={`comment-${comment.id}`} data-id={comment.id}>
          <div class="comment-header">
            <span class="comment-author">{comment.username || 'Anonymous'}</span>
            <span class="comment-date">{formatDate(comment.createdAt)}</span>
            {user && user.id === comment.userId && (
              <button class="comment-delete-btn" data-id={comment.id} title="Delete comment">×</button>
            )}
          </div>
          <p class="comment-body">{comment.body}</p>
          {user && (
            <button class="comment-reply-btn" data-parent-id={comment.id}>Reply</button>
          )}
          {replies(comment.id).map(reply => (
            <div class="comment comment--reply" id={`comment-${reply.id}`} data-id={reply.id}>
              <div class="comment-header">
                <span class="comment-author">{reply.username || 'Anonymous'}</span>
                <span class="comment-date">{formatDate(reply.createdAt)}</span>
                {user && user.id === reply.userId && (
                  <button class="comment-delete-btn" data-id={reply.id} title="Delete comment">×</button>
                )}
              </div>
              <p class="comment-body">{reply.body}</p>
            </div>
          ))}
          <div class="reply-form-container" id={`reply-form-${comment.id}`} style="display:none"></div>
        </div>
      ))
    )}
  </div>

  {user ? (
    <form class="comment-form" id="comment-form" data-entry-id={entryId}>
      <input type="hidden" name="parentId" id="comment-parent-id" value="" />
      <div id="reply-context" class="reply-context" style="display:none">
        <span id="reply-context-label"></span>
        <button type="button" id="cancel-reply-btn">× Cancel reply</button>
      </div>
      <textarea
        name="body"
        id="comment-body"
        class="comment-textarea"
        placeholder="Write a comment…"
        rows={4}
        maxlength={2000}
        required
      ></textarea>
      <div class="comment-form-footer">
        <span class="comment-char-count"><span id="char-count">0</span>/2000</span>
        <button type="submit" class="btn btn-primary comment-submit-btn">Post comment</button>
      </div>
      <div id="comment-error" class="comment-error" style="display:none"></div>
    </form>
  ) : (
    <p class="comments-login-prompt">
      <a href="/login">Log in</a> to leave a comment.
    </p>
  )}
</section>

<script>
  const form = document.getElementById('comment-form') as HTMLFormElement | null;
  const entryId = form?.dataset.entryId;
  const bodyInput = document.getElementById('comment-body') as HTMLTextAreaElement | null;
  const parentInput = document.getElementById('comment-parent-id') as HTMLInputElement | null;
  const charCount = document.getElementById('char-count');
  const errorEl = document.getElementById('comment-error');
  const replyContext = document.getElementById('reply-context');
  const replyContextLabel = document.getElementById('reply-context-label');
  const cancelReplyBtn = document.getElementById('cancel-reply-btn');

  bodyInput?.addEventListener('input', () => {
    if (charCount) charCount.textContent = String(bodyInput.value.length);
  });

  cancelReplyBtn?.addEventListener('click', () => {
    if (parentInput) parentInput.value = '';
    if (replyContext) replyContext.style.display = 'none';
    bodyInput?.focus();
  });

  document.querySelectorAll<HTMLButtonElement>('.comment-reply-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const parentId = btn.dataset.parentId || '';
      if (parentInput) parentInput.value = parentId;
      if (replyContext) replyContext.style.display = 'flex';
      if (replyContextLabel) replyContextLabel.textContent = `Replying to comment #${parentId}`;
      bodyInput?.focus();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.comment-delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = Number(btn.dataset.id);
      if (!id || !confirm('Delete this comment?')) return;
      const res = await fetch(`/api/comments/${entryId}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      if (res.ok) {
        document.getElementById(`comment-${id}`)?.remove();
        updateCount(-1);
      }
    });
  });

  function updateCount(delta: number) {
    const title = document.querySelector('.comments-title');
    if (!title) return;
    const match = title.textContent?.match(/(\d+)/);
    if (match) {
      const n = Math.max(0, Number(match[1]) + delta);
      title.textContent = title.textContent!.replace(/\d+/, String(n));
    }
  }

  function escapeHtml(s: string): string {
    const d = document.createElement('div');
    d.appendChild(document.createTextNode(s));
    return d.innerHTML;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!bodyInput || !entryId) return;
    const body = bodyInput.value.trim();
    if (!body) return;

    const submitBtn = form.querySelector<HTMLButtonElement>('.comment-submit-btn');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Posting…'; }
    if (errorEl) errorEl.style.display = 'none';

    try {
      const res = await fetch(`/api/comments/${entryId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body, parentId: parentInput?.value ? Number(parentInput.value) : null }),
      });

      const data = await res.json();
      if (!res.ok) {
        if (errorEl) { errorEl.textContent = data.error || 'Failed to post comment'; errorEl.style.display = 'block'; }
        return;
      }

      const parentId = data.parentId;
      const commentHtml = `
        <div class="comment${parentId ? ' comment--reply' : ''}" id="comment-${data.id}" data-id="${data.id}">
          <div class="comment-header">
            <span class="comment-author">${escapeHtml(data.username || 'You')}</span>
            <span class="comment-date">Just now</span>
            <button class="comment-delete-btn" data-id="${data.id}" title="Delete comment">×</button>
          </div>
          <p class="comment-body">${escapeHtml(data.body)}</p>
        </div>
      `;

      const list = document.getElementById('comments-list');
      if (list) {
        const empty = list.querySelector('.comments-empty');
        if (empty) empty.remove();

        if (parentId) {
          const parentEl = document.getElementById(`comment-${parentId}`);
          const replyContainer = parentEl?.querySelector('.reply-form-container');
          if (replyContainer) {
            replyContainer.insertAdjacentHTML('beforebegin', commentHtml);
          } else {
            list.insertAdjacentHTML('beforeend', commentHtml);
          }
        } else {
          list.insertAdjacentHTML('beforeend', commentHtml);
        }
        updateCount(1);
      }

      bodyInput.value = '';
      if (charCount) charCount.textContent = '0';
      if (parentInput) parentInput.value = '';
      if (replyContext) replyContext.style.display = 'none';

      // Wire delete btn on new comment
      document.querySelector(`#comment-${data.id} .comment-delete-btn`)?.addEventListener('click', async (ev) => {
        const btn = ev.currentTarget as HTMLButtonElement;
        const cid = Number(btn.dataset.id);
        if (!cid || !confirm('Delete this comment?')) return;
        const r = await fetch(`/api/comments/${entryId}`, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: cid }),
        });
        if (r.ok) { document.getElementById(`comment-${cid}`)?.remove(); updateCount(-1); }
      });

    } catch {
      if (errorEl) { errorEl.textContent = 'Network error — try again'; errorEl.style.display = 'block'; }
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Post comment'; }
    }
  });
</script>

<style>
  .comments-section {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .comments-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .comments-empty {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  .comment {
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3);
    background: var(--color-bg);
  }

  .comment--reply {
    margin-left: var(--space-8);
    margin-top: var(--space-2);
    background: var(--color-bg-secondary);
  }

  .comment-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }

  .comment-author {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .comment-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .comment-delete-btn {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0 4px;
    transition: color var(--transition-fast);
  }

  .comment-delete-btn:hover {
    color: var(--color-error, #e53e3e);
  }

  .comment-body {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
  }

  .comment-reply-btn {
    background: none;
    border: none;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    cursor: pointer;
    padding: var(--space-1) 0;
    margin-top: var(--space-2);
    transition: color var(--transition-fast);
  }

  .comment-reply-btn:hover {
    color: var(--color-accent);
  }

  .comment-form {
    margin-top: var(--space-6);
  }

  .reply-context {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    margin-bottom: var(--space-2);
    background: var(--color-accent-alpha);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--color-text);
  }

  #cancel-reply-btn {
    background: none;
    border: none;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    cursor: pointer;
    margin-left: auto;
  }

  .comment-textarea {
    width: 100%;
    padding: var(--space-3);
    font-size: var(--text-sm);
    font-family: inherit;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    resize: vertical;
    transition: border-color var(--transition-fast);
    box-sizing: border-box;
  }

  .comment-textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .comment-form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-2);
  }

  .comment-char-count {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .comment-error {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-error, #e53e3e);
  }

  .comments-login-prompt {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .comment--reply {
      margin-left: var(--space-4);
    }
  }
</style>
