---
import { getDb, schema } from '../lib/db/index';
import { eq } from 'drizzle-orm';

const REACTION_META = [
  { type: 'like',       emoji: '👍', label: 'Like'       },
  { type: 'love',       emoji: '❤️', label: 'Love'       },
  { type: 'fire',       emoji: '🔥', label: 'Fire'       },
  { type: 'insightful', emoji: '💡', label: 'Insightful' },
] as const;

interface Props {
  entryId: string;
  user?: { id: number; email: string; username: string } | null;
}

const { entryId, user } = Astro.props;

type ReactionRow = { type: string; userId: number };
let rows: ReactionRow[] = [];
try {
  const db = getDb();
  rows = db
    .select({ type: schema.reactions.type, userId: schema.reactions.userId })
    .from(schema.reactions)
    .where(eq(schema.reactions.entryId, entryId))
    .all();
} catch {
  // DB not available during prerender
}

const counts: Record<string, number> = { like: 0, love: 0, fire: 0, insightful: 0 };
const userReacted = new Set<string>();
for (const r of rows) {
  counts[r.type] = (counts[r.type] || 0) + 1;
  if (user && r.userId === user.id) userReacted.add(r.type);
}
---

<div class="reactions" id="reactions" data-entry-id={entryId}>
  {REACTION_META.map(({ type, emoji, label }) => {
    const count = counts[type] || 0;
    const active = userReacted.has(type);
    return (
      <button
        class={`reaction-btn${active ? ' reaction-btn--active' : ''}`}
        data-type={type}
        data-active={active ? 'true' : 'false'}
        title={user ? `${active ? 'Remove' : 'Add'} ${label}` : 'Log in to react'}
        disabled={!user}
      >
        <span class="reaction-emoji">{emoji}</span>
        <span class="reaction-count" data-type={type}>{count > 0 ? count : ''}</span>
      </button>
    );
  })}
  {!user && (
    <a href="/login" class="reactions-login-hint">Log in to react</a>
  )}
</div>

<script>
  const container = document.getElementById('reactions') as HTMLDivElement | null;
  const entryId = container?.dataset.entryId;
  if (!entryId || !container) throw new Error('reactions: missing entry id');

  container.querySelectorAll<HTMLButtonElement>('.reaction-btn:not([disabled])').forEach(btn => {
    btn.addEventListener('click', async () => {
      const type = btn.dataset.type;
      if (!type) return;

      // Optimistic update
      const wasActive = btn.dataset.active === 'true';
      const countEl = container.querySelector<HTMLSpanElement>(`.reaction-count[data-type="${type}"]`);
      const current = parseInt(countEl?.textContent || '0', 10) || 0;
      const next = wasActive ? Math.max(0, current - 1) : current + 1;

      btn.dataset.active = wasActive ? 'false' : 'true';
      btn.classList.toggle('reaction-btn--active', !wasActive);
      if (countEl) countEl.textContent = next > 0 ? String(next) : '';

      try {
        const res = await fetch(`/api/reactions/${entryId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type }),
        });
        if (!res.ok) throw new Error('failed');
      } catch {
        // Revert optimistic update
        btn.dataset.active = wasActive ? 'true' : 'false';
        btn.classList.toggle('reaction-btn--active', wasActive);
        if (countEl) countEl.textContent = current > 0 ? String(current) : '';
      }
    });
  });
</script>

<style>
  .reactions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-6);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border-light, var(--color-border));
  }

  .reaction-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border: 1.5px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all var(--transition-fast, 0.15s);
    color: var(--color-text-muted);
    user-select: none;
  }

  .reaction-btn:not([disabled]):hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-alpha, rgba(124,58,237,0.08));
  }

  .reaction-btn--active {
    border-color: var(--color-accent) !important;
    background: var(--color-accent-alpha, rgba(124,58,237,0.1)) !important;
    color: var(--color-accent) !important;
  }

  .reaction-btn[disabled] {
    cursor: default;
    opacity: 0.8;
  }

  .reaction-emoji {
    font-size: 1em;
    line-height: 1;
  }

  .reaction-count {
    font-size: var(--text-xs);
    font-weight: 600;
    min-width: 0.75em;
    text-align: center;
    color: inherit;
  }

  .reactions-login-hint {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-left: var(--space-2);
  }
</style>
