---
import type { CollectionEntry } from 'astro:content';
import ReadingTime from './ReadingTime.astro';

interface Props {
  entry: CollectionEntry<'entries'>;
  showCategory?: boolean;
}

const { entry, showCategory = false } = Astro.props;
const { title, category, tags, date_created, date_updated, excerpt, maturity } = entry.data;
const categorySlug = entry.id.split('/')[0];
---

<a href={`/entries/${entry.id}`} class="entry-card" data-maturity={maturity}>
  <div class="entry-card-header">
    <h3 class="entry-card-title">{title}</h3>
    <div class="entry-card-date-group">
      <span class="entry-card-date">
        {new Date(date_created).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </span>
      {date_updated && (
        <span class="entry-card-updated" title={`Updated ${new Date(date_updated).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`}>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </span>
      )}
    </div>
  </div>

  {excerpt && <p class="entry-card-excerpt">{excerpt}</p>}

  <div class="entry-card-footer">
    <div class="entry-card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="tag">#{tag}</span>
      ))}
      {maturity === 'draft' && (
        <span class="tag" style="color: var(--color-text-light);">draft</span>
      )}
    </div>
    <ReadingTime body={entry.body || ''} />
  </div>
</a>

<style>
  .entry-card-date-group {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex-shrink: 0;
  }

  .entry-card-updated {
    color: var(--color-text-light);
    opacity: 0.6;
    display: inline-flex;
    align-items: center;
  }
</style>
