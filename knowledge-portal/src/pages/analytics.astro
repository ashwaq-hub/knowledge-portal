---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Analytics" description="Local page view analytics dashboard">
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Analytics</h1>
      <p class="page-description">Local page view tracking — no vendors, no cookies, all data stays in your browser.</p>
    </header>

    <div id="analytics-dashboard" class="analytics-dashboard">
      <p class="analytics-loading">Loading dashboard...</p>
    </div>
  </div>
</BaseLayout>

<script>
  import { renderAnalyticsDashboard } from '../scripts/analytics.ts';

  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('analytics-dashboard');
    if (container) {
      renderAnalyticsDashboard(container);
    }
  });
</script>

<style>
  .analytics-dashboard {
    max-width: 700px;
    margin: 0 auto;
  }

  .analytics-loading {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-8);
  }

  .analytics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .analytics-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .analytics-card-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }

  .analytics-card-value {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .analytics-section-title {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-3);
    margin-top: var(--space-8);
    color: var(--color-text);
  }

  .analytics-list {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .analytics-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-light);
    transition: background var(--transition-fast);
  }

  .analytics-row:last-child {
    border-bottom: none;
  }

  .analytics-row:hover {
    background: var(--color-bg-secondary);
  }

  .analytics-rank {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    width: 24px;
    text-align: right;
  }

  .analytics-row-title {
    flex: 1;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .analytics-row-count {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    min-width: 32px;
    text-align: right;
  }

  .analytics-heatmap {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .analytics-heatmap-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .analytics-heatmap-row:last-child {
    margin-bottom: 0;
  }

  .analytics-heatmap-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    width: 120px;
    text-transform: capitalize;
    flex-shrink: 0;
  }

  .analytics-heatmap-bar-wrap {
    flex: 1;
    height: 20px;
    background: var(--color-bg-secondary);
    border-radius: 999px;
    overflow: hidden;
  }

  .analytics-heatmap-bar {
    height: 100%;
    background: var(--color-accent);
    border-radius: 999px;
    transition: width 0.5s ease;
    min-width: 4px;
  }

  .analytics-heatmap-count {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    width: 40px;
    text-align: right;
  }

  .analytics-weekly {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    height: 140px;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .analytics-weekly-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
  }

  .analytics-weekly-bar {
    width: 100%;
    max-width: 36px;
    background: var(--color-accent);
    border-radius: 4px 4px 0 0;
    transition: height 0.5s ease;
    min-height: 4px;
  }

  .analytics-weekly-label {
    font-size: 10px;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .analytics-weekly-count {
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-light);
  }
</style>
