---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import EntryTable from '../../components/EntryTable.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const allEntries = await getCollection('entries');
  const tagSet = new Set<string>();
  allEntries.forEach(e => e.data.tags.forEach(t => tagSet.add(t)));
  return [...tagSet].map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allEntries = await getCollection('entries');

const tagEntries = allEntries
  .filter(e => e.data.tags.includes(tag!))
  .sort((a, b) => new Date(b.data.date_created).getTime() - new Date(a.data.date_created).getTime());
---

<BaseLayout title={`#${tag}`} description={`Entries tagged with ${tag}`}>
  <div class="container">
    <header class="page-header">
      <p class="breadcrumbs">
        <a href="/tags" class="breadcrumb-link">Tags</a>
        <span class="breadcrumb-separator">/</span>
        <span class="breadcrumb-current">#{tag}</span>
      </p>
      <h1 class="page-title">#<span style="color: var(--color-accent);">{tag}</span></h1>
      <p class="page-description">
        {tagEntries.length} entr{tagEntries.length === 1 ? 'y' : 'ies'} tagged with {tag}
      </p>
      <div class="view-toggle">
        <button id="tag-view-card" class="view-toggle-btn active" onclick="switchTagView('card')" title="Card view">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="1" width="6" height="6"/><rect x="9" y="1" width="6" height="6"/><rect x="1" y="9" width="6" height="6"/><rect x="9" y="9" width="6" height="6"/></svg>
        </button>
        <button id="tag-view-table" class="view-toggle-btn" onclick="switchTagView('table')" title="Table view">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 3h14M1 8h14M1 13h14"/><path d="M1 3v10a1 1 0 001 1h12a1 1 0 001-1V3a1 1 0 00-1-1H2a1 1 0 00-1 1z"/></svg>
        </button>
      </div>
    </header>

    <div id="tag-card-view" class="entry-list">
      {tagEntries.map(entry => <EntryCard entry={entry} />)}
    </div>
    <div id="tag-table-view" style="display: none;">
      <EntryTable entries={tagEntries} />
    </div>
  </div>
</BaseLayout>

<script>
  (window as any).switchTagView = function(view: string) {
    const cardView = document.getElementById('tag-card-view');
    const tableView = document.getElementById('tag-table-view');
    const cardBtn = document.getElementById('tag-view-card');
    const tableBtn = document.getElementById('tag-view-table');

    if (view === 'table') {
      if (cardView) cardView.style.display = 'none';
      if (tableView) tableView.style.display = 'block';
      if (cardBtn) cardBtn.classList.remove('active');
      if (tableBtn) tableBtn.classList.add('active');
    } else {
      if (cardView) cardView.style.display = 'block';
      if (tableView) tableView.style.display = 'none';
      if (cardBtn) cardBtn.classList.add('active');
      if (tableBtn) tableBtn.classList.remove('active');
    }
  };
</script>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .breadcrumb-separator { color: var(--color-text-light); }
  .breadcrumb-link { color: var(--color-text-muted); }
  .breadcrumb-link:hover { color: var(--color-accent); }
  .breadcrumb-current { color: var(--color-text); }

  .view-toggle {
    display: flex;
    gap: var(--space-1);
    margin-top: var(--space-4);
  }

  .view-toggle-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .view-toggle-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .view-toggle-btn.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }
</style>
