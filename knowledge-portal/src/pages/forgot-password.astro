---
import BaseLayout from '../layouts/BaseLayout.astro';

const user = Astro.locals.currentUser;
if (user) return Astro.redirect('/admin');
---

<BaseLayout title="Forgot password">
  <div class="auth-page">
    <div class="auth-card">
      <h1>Forgot your password?</h1>
      <p class="auth-description">Enter your email and we'll send you a reset link.</p>
      <form id="forgotForm">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div id="forgotMessage" class="form-message" hidden></div>
        <button type="submit" class="btn btn-primary">Send reset link</button>
      </form>
      <p class="auth-alt"><a href="/login">← Back to login</a></p>
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('forgotForm')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const msgEl = document.getElementById('forgotMessage') as HTMLDivElement;
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    msgEl.hidden = true;
    msgEl.className = 'form-message';

    try {
      await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: (form.querySelector<HTMLInputElement>('#email')!).value }),
      });
      // Always show success to prevent enumeration
      msgEl.textContent = 'If an account exists for that email, a reset link has been sent.';
      msgEl.classList.add('form-message--success');
      msgEl.hidden = false;
      form.reset();
    } catch {
      msgEl.textContent = 'Network error — please try again.';
      msgEl.classList.add('form-message--error');
      msgEl.hidden = false;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send reset link';
    }
  });
</script>

<style is:global>
  .auth-description {
    color: var(--color-text-muted, #6b7280);
    font-size: 0.9375rem;
    margin: 0 0 1.25rem;
  }
  .form-message {
    padding: 0.625rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }
  .form-message--success {
    background: rgba(16,185,129,0.1);
    border: 1px solid #10b981;
    color: #065f46;
  }
  .form-message--error {
    background: rgba(239,68,68,0.1);
    border: 1px solid #ef4444;
    color: #991b1b;
  }
</style>
