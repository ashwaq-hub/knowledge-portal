# Email (Resend — https://resend.com)
RESEND_API_KEY=re_...

# The from address for outgoing emails
EMAIL_FROM=Knowledge Portal <no-reply@yourdomain.com>

# Public site URL (used in email links)
SITE_URL=http://localhost:4321

# Optional: secret token to protect the cron endpoint
# Set this and pass as Authorization: Bearer <secret> when calling /api/cron/send-emails
CRON_SECRET=
