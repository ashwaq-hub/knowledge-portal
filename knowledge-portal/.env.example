# ─── Email ────────────────────────────────────────────────────────────────────
# Resend API key (https://resend.com → API Keys → Create)
# If unset, emails are printed to console (dev-friendly fallback)
RESEND_API_KEY=re_...

# From address for outgoing emails
# Must be from a verified domain, or use onboarding@resend.dev for the free tier
EMAIL_FROM=Knowledge Portal <no-reply@yourdomain.com>

# ─── Site ─────────────────────────────────────────────────────────────────────
# Base URL used in email links and meta tags
# No trailing slash
SITE_URL=http://localhost:4321

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Bearer token protecting POST /api/cron/send-emails
# Pass as:  Authorization: Bearer <value>
# Leave empty to allow unauthenticated calls (fine locally)
CRON_SECRET=
